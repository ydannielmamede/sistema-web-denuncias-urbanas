# Copie este arquivo para `.env` e ajuste conforme necessário.
# Em desenvolvimento local (DEBUG=True), sem DATABASE_URL/DB_*,
# o sistema usa SQLite automaticamente — basta rodar:
#     python manage.py runserver

# Ambiente
DEBUG=True
SECRET_KEY=django-insecure-dev-only-key-change-me-in-production-7#f8!k2pz9xq
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1

# Banco de dados (opcional em dev). Defina DATABASE_URL para usar MySQL/Postgres.
# Exemplo MySQL: mysql://usuario:senha@host:3306/nome_do_banco
# Exemplo Postgres: postgres://usuario:senha@host:5432/nome_do_banco
DATABASE_URL=

# Usado apenas se DATABASE_URL estiver vazio e DEBUG=False (produção)
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=

# Login social (django-allauth). Preencha com as chaves obtidas no Google Cloud Console.
# Redirect URI dev: http://localhost:8000/accounts/google/login/callback/
# Redirect URI produção: https://<seu-dominio>/accounts/google/login/callback/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SITE_DOMAIN=localhost:8000